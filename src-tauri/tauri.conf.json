{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sentinel",
  "version": "0.1.0",
  "identifier": "com.dr-tiphanie-mercier.sentinel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "sentinel",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/sentinel-backend"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
